# Copy thành .env và điền giá trị thật
CORS_ORIGINS=http://localhost:3000

# === Mặc định: Groq (free, không cần thẻ) ===
# Lấy key: https://console.groq.com/keys
GROQ_API_KEY=gsk_paste_key_thật_vào_đây

# === Nếu sau muốn nâng cấp lên Claude (paid, chất lượng cao hơn) ===
# Đổi LLM_PROVIDER=anthropic và điền key dưới
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-api03-...

# === Nếu muốn dùng OpenAI Whisper riêng (paid, không bắt buộc) ===
# OPENAI_API_KEY=sk-proj-...
